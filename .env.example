# Copy this file to .env.local and fill in real values for local dev.
# Production values live in Vercel: Project → Settings → Environment Variables.

# ─── Resend (transactional email) ──────────────────────────
RESEND_API_KEY=

# ─── Plasmic Builder (visual editor) ──────────────────────
# Both come from Plasmic Studio: https://studio.plasmic.app
#   Project Settings → API tokens → copy "Project ID" + "Public token"
VITE_PLASMIC_PROJECT_ID=
VITE_PLASMIC_PUBLIC_TOKEN=

# ─── Admin auth ────────────────────────────────────────────
# Generated by `node scripts/admin-password.js <password>` and pasted in
# Vercel env. Not needed locally unless testing the admin panel offline.
STRIKEPRINT_ADMIN_PASSWORD_HASH=
STRIKEPRINT_ADMIN_JWT_SECRET=
